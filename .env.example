# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Mapbox (presentation layer only) ───
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# ─── Geoapify (backend-only, never exposed to client) ───
GEOAPIFY_API_KEY=your-geoapify-api-key

# ─── AI Enrichment (backend-only) ───
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── PMS Integration (backend-only) ───
PMS_WEBHOOK_API_KEY=your-pms-webhook-api-key
ADMIN_SYNC_KEY=your-admin-sync-key
APP_URL=your-app-url

# ─── Upstash Redis (rate limiting, backend-only) ───
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token
